# OpenRouter Configuration
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://antigravity-openrouter.app
OPENROUTER_APP_TITLE=Antigravity BYOK Assistant

# Security
API_KEY_COOKIE_NAME=openrouter_api_key
